# LLM 配置（兼容 OpenAI API 格式的服务均可）
# Ollama 本地部署: 确保已执行 `ollama pull glm-4.7-flash` 并启动 ollama serve
# 如需切换其他 OpenAI 兼容服务，修改 LLM_BASE_URL 和 LLM_MODEL 即可
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=glm-4.7-flash

# Milvus 配置（Lite 模式：本地文件路径）
# 避免用 MILVUS_URI（pymilvus 内部也读这个环境变量，会冲突）
K12_MILVUS_URI=./milvus_k12.db

# Embedding 模型配置
# 可选: BAAI/bge-large-zh-v1.5 (1024维), BAAI/bge-small-zh-v1.5 (512维, 速度更快)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# 稠密向量检索：Milvus COSINE 相似度下限（0~1），低于则丢弃；0 表示关闭阈值过滤
# DENSE_MIN_SIMILARITY=0.30

# HuggingFace 镜像（国内网络需要配置）
HF_ENDPOINT=https://hf-mirror.com

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
